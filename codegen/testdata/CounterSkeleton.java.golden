    private byte[] handleGetInfo(byte p1, byte p2, byte[] requestData) {
        byte[] out = onGetInfo();
        return safeBytes(out);
    }

    private byte[] handleStore(byte p1, byte p2, byte[] requestData) {
        // request: data(bytes) in request data
        byte[] data = slice(requestData, 0, requestData.length - 0);
        onStore(data);
        return EMPTY;
    }

    private byte[] handleLoad(byte p1, byte p2, byte[] requestData) {
        byte[] src = safeBytes(onLoad());
        byte[] out = new byte[src.length];
        packBytes(out, 0, src, 0, src.length);
        return out;
    }

    private byte[] handleSetCount(byte p1, byte p2, byte[] requestData) {
        // request: value(u32) in data
        if (requestData.length < 4) {
            throw new StatusWordException(SW_WRONG_LENGTH);
        }
        int value = readU32(requestData, 0);
        onSetCount(value);
        return EMPTY;
