    private byte[] handleSetEnabled(byte p1, byte p2, byte[] requestData) {
        // request: enabled(bool) in P1
        boolean enabled = readBool(p1);
        onSetEnabled(enabled);
        return EMPTY;
    }

    private byte[] handleGetHash(byte p1, byte p2, byte[] requestData) {
        byte[] src = safeBytes(onGetHash());
        if (src.length != 32) {
            throw new StatusWordException(SW_WRONG_LENGTH);
        }
        byte[] out = new byte[32];
        packBytes(out, 0, src, 0, 32);
        return out;
    }

    // --- Abstract methods — developer implements these ---

    /** increment(amount: u8) → value: u16 */
    protected abstract short onIncrement(byte amount);

    /** decrement(amount: u8) → value: u16 */
