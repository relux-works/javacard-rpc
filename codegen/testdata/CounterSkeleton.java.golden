    // --- Dispatch wiring (reads request fields, calls abstract method, returns encoded response) ---

    private byte[] handleIncrement(byte p1, byte p2, byte[] requestData) {
        // request: amount(u8) in P1
        byte amount = p1;
        short value = onIncrement(amount);
        byte[] out = new byte[2];
        packU16(out, 0, value);
        return out;
