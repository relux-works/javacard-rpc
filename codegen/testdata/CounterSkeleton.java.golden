    private static final byte INS_INCREMENT    = (byte) 0x01;
    private static final byte INS_DECREMENT    = (byte) 0x02;
    private static final byte INS_GET          = (byte) 0x03;
    private static final byte INS_RESET        = (byte) 0x04;
    private static final byte INS_SET_LIMIT    = (byte) 0x05;
    private static final byte INS_GET_INFO     = (byte) 0x06;
    private static final byte INS_STORE        = (byte) 0x07;
    private static final byte INS_LOAD         = (byte) 0x08;
    private static final byte INS_SET_COUNT    = (byte) 0x09;
    private static final byte INS_SET_ENABLED  = (byte) 0x0A;
    private static final byte INS_GET_HASH     = (byte) 0x0B;

    // Status words from counter.toml
    public static final short SW_UNDERFLOW     = (short) 0x6985;
    public static final short SW_OVERFLOW      = (short) 0x6986;
    public static final short SW_NO_DATA       = (short) 0x6A88;
    public static final short SW_DATA_TOO_LONG = (short) 0x6A80;

    public static final byte CLA_COUNTER = (byte) 0xB0;

    private static final short SW_WRONG_LENGTH = (short) 0x6700;
    private static final short SW_INS_NOT_SUPPORTED = (short) 0x6D00;
    private static final byte[] EMPTY = new byte[0];

    protected final CounterTransport transport;

    protected CounterSkeleton(CounterTransport transport) {
        if (transport == null) {
            throw new IllegalArgumentException("transport is null");
        }
        this.transport = transport;
    }

    public final byte[] dispatch(byte ins, byte p1, byte p2, byte[] data) {
        byte[] requestData = safeBytes(data);
        switch (ins) {
            case INS_INCREMENT:
                return handleIncrement(p1, p2, requestData);
            case INS_DECREMENT:
                return handleDecrement(p1, p2, requestData);
            case INS_GET:
                return handleGet(p1, p2, requestData);
            case INS_RESET:
                onReset();
                return EMPTY;
            case INS_SET_LIMIT:
                return handleSetLimit(p1, p2, requestData);
            case INS_GET_INFO:
                return handleGetInfo(p1, p2, requestData);
            case INS_STORE:
