        return out;
    }

    private byte[] handleSetLimit(byte p1, byte p2, byte[] requestData) {
        // request: limit(u16) in data
        if (requestData.length < 2) {
            throw new StatusWordException(SW_WRONG_LENGTH);
        }
        short limit = readU16(requestData, 0);
        onSetLimit(limit);
        return EMPTY;
